# Environment Variables Reference
# =================================
# Copy this file to .env.local (React) or set as environment variables
# when hosting on Render, Railway, Vercel, etc.
# NEVER commit actual secret values to GitHub.

# ─── React Frontend (prefix with REACT_APP_ for CRA) ───────────────────────
# These go in Vercel / Netlify / Render Static Site environment settings:
REACT_APP_API_URL=https://pmo-spring-boot.onrender.com
REACT_APP_AI_API_URL=https://pmo-candidate-shortlist.onrender.com
REACT_APP_RESUME_API_URL=https://pmo-resume-screening.onrender.com
REACT_APP_NODE_API_URL=https://pmo-spring-boot.onrender.com

# ─── Spring Boot Backend ────────────────────────────────────────────────────
# These go in Render → pmo-spring-boot → Environment:
DB_URL=jdbc:postgresql://db.cfqpdjpvzgkvpipainzp.supabase.co:5432/postgres
DB_USERNAME=postgres
DB_PASSWORD=<your-supabase-db-password>
python_skillsmatch_url=https://pmo-candidate-shortlist.onrender.com/match-skills/
app_frontend_url=https://<your-vercel-app>.vercel.app
MAIL_PASSWORD=<your-gmail-app-password>
FILE_STORAGE_LOCATION=./upload

# ─── Candidate Shortlist FastAPI ────────────────────────────────────────────
# These go in Render → pmo-candidate-shortlist → Environment:
DATABASE_URL=postgresql://postgres.cfqpdjpvzgkvpipainzp:<password>@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ─── Resume Screening FastAPI ───────────────────────────────────────────────
# These go in Render → pmo-resume-screening → Environment:
OPENAI_API_KEY=<your-openai-api-key>

# ─── Supabase Migration Script ──────────────────────────────────────────────
# Used when running migrate_supabase_http.py:
SUPABASE_TOKEN=<your-supabase-personal-access-token>
ADMIN_PASSWORD=<initial-admin-password>
